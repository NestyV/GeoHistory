{
  "name": "geohistory",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "node scripts/generate_database_setup.js",
    "db:watch": "node scripts/watch_schema.js",
    "dev:all": "concurrently \"npm run db:watch\" \"npm run dev\"",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "leaflet": "^1.9.4",
    "next": "^14.2.0",
    "react": "^18",
    "react-dom": "^18",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.8",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^8",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  }
}
